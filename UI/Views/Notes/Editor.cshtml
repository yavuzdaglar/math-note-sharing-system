@{
    ViewData["Title"] = "Not Düzenle";
}

<link rel="stylesheet" href="~/css/block-editor.css" />

<button type="button" onclick="history.back()" class="fixed top-4 left-4 z-[9999] flex items-center gap-2 rounded-full border border-slate-200 bg-white/90 px-3 py-2 text-sm font-semibold text-slate-700 shadow-md backdrop-blur hover:bg-white dark:border-slate-700 dark:bg-slate-900/80 dark:text-slate-200">
    <i data-lucide="arrow-left" class="w-4 h-4"></i>
    <span>Geri</span>
</button>

<div class="editor-container">
    <input type="text" id="noteTitle" class="note-title-input" placeholder="Not Başlığı..." />
    
    <div id="blockList" class="block-list">
        <!-- Bloklar buraya gelecek -->
    </div>

    <!-- Yayınlama Modalı -->
    <div id="publishModal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4">
        <div class="absolute inset-0 bg-slate-900/60 backdrop-blur-sm" onclick="closePublishModal()"></div>
        <div class="bg-white text-slate-900 relative z-10 w-full max-w-lg rounded-[3rem] p-10 shadow-2xl">
            <h3 class="text-2xl font-black text-slate-900 mb-2">Notu Yayınla</h3>
            <p class="text-slate-500 text-sm mb-8 font-medium">Bu notun hangi ders altında görüneceğini seçin.</p>
            
            <div class="space-y-6">
                <div>
                    <label class="block text-xs font-black text-slate-400 uppercase mb-2 ml-2">Kategori</label>
                    <select id="categorySelect" onchange="loadCourses(this.value)" class="w-full p-4 bg-slate-50 text-slate-900 border border-slate-100 rounded-2xl outline-none focus:ring-4 focus:ring-brand-teal/10">
                        <option value="">Kategori Seçin...</option>
                    </select>
                </div>

                <div>
                    <label class="block text-xs font-black text-slate-400 uppercase mb-2 ml-2">Ders</label>
                    <select id="courseSelect" class="w-full p-4 bg-slate-50 text-slate-900 border border-slate-100 rounded-2xl outline-none focus:ring-4 focus:ring-brand-teal/10">
                        <option value="">Önce Kategori Seçin...</option>
                    </select>
                </div>

                <div class="pt-4 flex gap-3">
                    <button onclick="confirmPublish()" class="flex-1 py-5 bg-brand-teal text-white font-black rounded-2xl shadow-xl shadow-teal-100 hover:bg-brand-teal-light transition-all transform hover:scale-[1.02]">Onayla ve Yayınla</button>
                    <button onclick="closePublishModal()" class="px-8 py-5 bg-slate-100 text-slate-500 font-bold rounded-2xl hover:bg-slate-200 transition-all">İptal</button>
                </div>
            </div>
        </div>
    </div>

<!-- Blok Tipi Seçme Paneli (Tailwind) -->
<div id="addBlockPanel" class="mt-12 p-8 bg-white rounded-3xl shadow-xl border border-gray-100 max-w-2xl mx-auto">
    <h3 class="text-center text-lg font-bold text-brand-navy mb-6">Yeni Bir Blok Ekleyin</h3>
    <div class="grid grid-cols-2 sm:grid-cols-3 gap-4">
        <button onclick="addBlock('Heading')" class="flex flex-col items-center p-4 rounded-2xl border-2 border-gray-50 hover:border-brand-teal hover:bg-teal-50 transition-all duration-300 group">
            <div class="bg-gray-100 p-3 rounded-xl group-hover:bg-brand-teal group-hover:text-white transition-colors mb-3">
                <i data-lucide="heading" class="w-6 h-6"></i>
            </div>
            <span class="text-sm font-bold text-gray-700">Başlık</span>
        </button>
        <button onclick="addBlock('Paragraph')" class="flex flex-col items-center p-4 rounded-2xl border-2 border-gray-50 hover:border-brand-teal hover:bg-teal-50 transition-all duration-300 group">
            <div class="bg-gray-100 p-3 rounded-xl group-hover:bg-brand-teal group-hover:text-white transition-colors mb-3">
                <i data-lucide="type" class="w-6 h-6"></i>
            </div>
            <span class="text-sm font-bold text-gray-700">Paragraf</span>
        </button>
        <button onclick="addBlock('ImportantNote')" class="flex flex-col items-center p-4 rounded-2xl border-2 border-gray-50 hover:border-brand-teal hover:bg-teal-50 transition-all duration-300 group">
            <div class="bg-gray-100 p-3 rounded-xl group-hover:bg-brand-teal group-hover:text-white transition-colors mb-3">
                <i data-lucide="info" class="w-6 h-6"></i>
            </div>
            <span class="text-sm font-bold text-gray-700">Önemli Not</span>
        </button>
        <button onclick="addBlock('Image')" class="flex flex-col items-center p-4 rounded-2xl border-2 border-gray-50 hover:border-brand-teal hover:bg-teal-50 transition-all duration-300 group">
            <div class="bg-gray-100 p-3 rounded-xl group-hover:bg-brand-teal group-hover:text-white transition-colors mb-3">
                <i data-lucide="image" class="w-6 h-6"></i>
            </div>
            <span class="text-sm font-bold text-gray-700">Resim</span>
        </button>
        <button onclick="addBlock('Video')" class="flex flex-col items-center p-4 rounded-2xl border-2 border-gray-50 hover:border-brand-teal hover:bg-teal-50 transition-all duration-300 group">
            <div class="bg-gray-100 p-3 rounded-xl group-hover:bg-brand-teal group-hover:text-white transition-colors mb-3">
                <i data-lucide="video" class="w-6 h-6"></i>
            </div>
            <span class="text-sm font-bold text-gray-700">Video</span>
        </button>
        <button onclick="addBlock('Code')" class="flex flex-col items-center p-4 rounded-2xl border-2 border-gray-50 hover:border-brand-teal hover:bg-teal-50 transition-all duration-300 group">
            <div class="bg-gray-100 p-3 rounded-xl group-hover:bg-brand-teal group-hover:text-white transition-colors mb-3">
                <i data-lucide="code" class="w-6 h-6"></i>
            </div>
            <span class="text-sm font-bold text-gray-700">Kod</span>
        </button>
    </div>
</div>

<div class="editor-actions-bar">
    <button type="button" onclick="applyTemplate()" class="px-6 py-2 rounded-full text-sm font-bold text-amber-600 bg-amber-50 hover:bg-amber-100 transition-all flex items-center gap-2">
        <i data-lucide="sparkles" class="w-4 h-4"></i> Şablon Uygula
    </button>
    <button type="button" onclick="previewNote()" class="px-6 py-2 rounded-full text-sm font-bold text-gray-500 hover:bg-gray-50 transition-all">Önizle</button>
    <button type="button" onclick="saveNote(false)" class="px-6 py-2 rounded-full text-sm font-bold text-gray-900 border border-gray-200 hover:bg-gray-50 transition-all">Taslak Kaydet</button>
    <button type="button" onclick="saveNote(true)" class="px-8 py-2 rounded-full text-sm font-bold text-white bg-brand-teal hover:bg-brand-teal-light shadow-lg shadow-teal-100 transition-all">Yayınla</button>
</div>

@section Scripts {
    <script src="~/js/block-editor.js"></script>
    <script>
        const noteId = @(ViewBag.NoteId ?? 0);
        
        async function fetchCategories() {
            const resp = await fetch('https://localhost:7078/api/coursecategories');
            const categories = await resp.json();
            const select = document.getElementById('categorySelect');
            categories.forEach(c => {
                select.innerHTML += `<option value="${c.id}">${c.name}</option>`;
            });
        }

        async function loadCourses(categoryId) {
            const select = document.getElementById('courseSelect');
            select.innerHTML = '<option value="">Ders Seçin...</option>';
            if (!categoryId) return;

            const resp = await fetch('https://localhost:7078/api/courses');
            const courses = await resp.json();
            const filtered = courses.filter(c => c.courseCategoryId == categoryId);
            filtered.forEach(c => {
                select.innerHTML += `<option value="${c.id}">${c.name}</option>`;
            });
        }

        window.onload = async () => {
            await fetchCategories();
            if (noteId > 0) {
                await loadNote(noteId);
            }
        };
    </script>
}
