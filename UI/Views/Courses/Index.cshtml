@model CoursesPageViewModel
@{
    ViewData["Title"] = "Dersler";
}

<div class="min-h-screen transition-all duration-500">
    <div class="bg-white dark:bg-[#0d161e] min-h-screen text-slate-900 dark:text-slate-100 flex flex-col transition-colors duration-500">
        @await Component.InvokeAsync("Navbar")

        <div class="flex flex-1">
            @await Component.InvokeAsync("Sidebar", new { categories = Model.Categories })

            <main id="main-content" class="flex-1 pt-16 min-h-screen transition-all duration-300 pl-64">
                <div class="max-w-4xl mx-auto py-20">
                    <div class="mb-10 pb-6 border-b border-slate-200 dark:border-slate-800">
                        <h2 class="text-5xl font-black mb-4 bg-gradient-to-r from-brand-navy to-brand-teal bg-clip-text text-transparent">
                            Dersler
                        </h2>
                        <p class="text-slate-500 dark:text-slate-400 font-medium">
                            Tüm dersler listesi
                        </p>
                    </div>

                    @if (Model.Courses.Count == 0)
                    {
                        <div class="p-8 rounded-3xl bg-slate-50 dark:bg-brand-navy/20 border border-slate-100 dark:border-white/5">
                            <p class="text-slate-500 dark:text-slate-400 font-medium">Henüz kayıtlı ders bulunamadı.</p>
                        </div>
                    }
                    else
                    {
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            @foreach (var course in Model.Courses)
                            {
                                <div class="p-6 rounded-3xl bg-slate-50 dark:bg-brand-navy/20 border border-slate-100 dark:border-white/5 shadow-sm">
                                    <h3 class="text-xl font-bold text-slate-900 dark:text-white mb-2">@course.Name</h3>
                                    <p class="text-slate-500 dark:text-slate-400 text-sm">Kategori ID: @course.CourseCategoryId</p>
                                </div>
                            }
                        </div>
                    }
                </div>
            </main>
        </div>
    </div>
</div>
