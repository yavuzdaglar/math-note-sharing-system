@model HomeViewModel
@{
    ViewData["Title"] = "Ana Sayfa";
    ViewData["ShowAdminLogin"] = true;
}

<div class="min-h-screen transition-all duration-500">
    <div class="bg-white dark:bg-[#0d161e] min-h-screen text-slate-900 dark:text-slate-100 flex flex-col transition-colors duration-500">
        @await Component.InvokeAsync("Navbar")

        <div class="flex flex-1">
            @await Component.InvokeAsync("Sidebar", new { categories = Model.Categories })

            <main id="main-content" class="flex-1 pt-16 min-h-screen transition-all duration-300 pl-64">
                <div id="loading-state" class="hidden h-full flex flex-col items-center justify-center pt-40">
                    <div class="w-12 h-12 border-4 border-blue-600 border-t-transparent rounded-full animate-spin mb-4"></div>
                    <p class="text-slate-400 font-medium">İçerik Yükleniyor...</p>
                </div>

                <div id="note-state" class="hidden max-w-4xl mx-auto">
                    <div class="mb-10 pb-6 border-b border-slate-200 dark:border-slate-800">
                        <h2 class="text-5xl font-black mb-4 bg-gradient-to-r from-brand-navy to-brand-teal bg-clip-text text-transparent" data-note-title>
                        </h2>
                        <p class="text-slate-500 dark:text-slate-400 font-medium flex items-center gap-2">
                            <i data-lucide="pi" class="text-brand-teal w-4 h-4"></i>
                            Matematik Bölümü / Akademik Notlar
                        </p>
                    </div>

                    <div class="bg-slate-50 dark:bg-brand-navy/20 p-12 rounded-[3.5rem] border border-slate-100 dark:border-white/5 shadow-2xl shadow-slate-200/50 dark:shadow-none mb-12">
                        <div class="prose dark:prose-invert max-w-none">
                            <h3 class="text-2xl font-bold dark:text-white mb-6">Özet Anlatım</h3>

                            <div class="space-y-8">
                                <p class="text-xl leading-relaxed text-slate-600 dark:text-slate-300">
                                    Bu döküman <strong data-note-title></strong> dersinin akademik derinliğini ve temel uygulamalarını analiz etmektedir.
                                    Aşağıdaki bölümlerde konuya ait görsel materyaller ve video özetleri yer almaktadır.
                                </p>

                                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                    <div class="group relative aspect-video bg-slate-200 dark:bg-brand-navy rounded-3xl overflow-hidden border border-slate-200 dark:border-white/10 shadow-inner flex flex-col items-center justify-center cursor-pointer transition-transform hover:scale-[1.02]">
                                        <div class="w-16 h-16 bg-brand-teal rounded-full flex items-center justify-center text-white shadow-lg group-hover:scale-110 transition-transform">
                                            <i data-lucide="play" class="w-8 h-8 fill-current"></i>
                                        </div>
                                        <span class="mt-4 font-bold text-slate-500 dark:text-slate-400">Video Anlatımı İzle</span>
                                        <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent pointer-events-none"></div>
                                    </div>

                                    <div class="group relative aspect-video bg-slate-200 dark:bg-brand-navy rounded-3xl overflow-hidden border border-slate-200 dark:border-white/10 shadow-inner flex flex-col items-center justify-center cursor-pointer transition-transform hover:scale-[1.02]">
                                        <div class="w-16 h-16 bg-brand-teal-light rounded-full flex items-center justify-center text-white shadow-lg group-hover:scale-110 transition-transform">
                                            <i data-lucide="image" class="w-8 h-8"></i>
                                        </div>
                                        <span class="mt-4 font-bold text-slate-500 dark:text-slate-400">Konu Grafikleri ve Görseller</span>
                                        <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent pointer-events-none"></div>
                                    </div>
                                </div>

                                <div class="p-8 rounded-3xl bg-brand-teal text-white shadow-xl shadow-brand-teal/20 backdrop-blur-sm">
                                    <h4 class="font-bold text-xl mb-3 flex items-center gap-2 italic underline decoration-brand-navy underline-offset-4">
                                        Önemli Bilgi
                                    </h4>
                                    <p class="opacity-90 leading-relaxed font-semibold">
                                        Daha fazla kaynak için kütüphane bölümünü ziyaret etmeyi unutmayın.
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div id="home-state" class="h-full flex flex-col items-center justify-center text-center py-20">
                    <div class="w-24 h-24 bg-brand-teal/10 dark:bg-brand-teal/20 rounded-3xl flex items-center justify-center mb-8 text-brand-teal shadow-inner">
                        <i data-lucide="pi" class="w-12 h-12"></i>
                    </div>
                    <h2 class="text-4xl font-black mb-4 dark:text-white uppercase tracking-tight">VURMAZ ONLİNE NOTLARI</h2>
                    <p class="text-slate-500 dark:text-slate-400 max-w-md text-lg">
                        Matematik serüvenine başlamak için sol menüden bir ders kategorisi seçin.
                    </p>
                </div>
            </main>

            @await Component.InvokeAsync("AdminLogin")
        </div>
    </div>
</div>